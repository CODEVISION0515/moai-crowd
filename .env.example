# ⚠️ このファイルはサンプルです。実際の値は .env.local に書き、絶対にコミットしないこと。
# 過去にこのファイルに本番キーを書いていた場合は、必ず該当キーをローテートしてください。

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Connect + Escrow)
# 開発時は sk_test_..., pk_test_... を使う。sk_live_ は絶対に .env.example に書かない。
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=10

# Resend (メール通知)
RESEND_API_KEY=re_xxx
MAIL_FROM="MOAI Crowd <noreply@moai.okinawa>"

# Webhook 保護
SUPABASE_WEBHOOK_SECRET=change-me

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_OFFICIAL_ACCOUNT_ID=@moai-crowd

# LLM プロバイダ: openrouter (default) | anthropic | gemini
LLM_PROVIDER=openrouter

# Anthropic (AI 下書き・マッチング)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Gemini (オプション: LLM_PROVIDER=gemini の場合)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (無料モデル対応)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
